{
  "manifest_version": 3,
  "name": "Twitter Image Saver (Auto-Scroll)",
  "version": "1.0.0",
  "description": "在 Twitter(X) 自動捲動、觀察載入並批次下載圖片。支援面板與熱鍵、orig→large 回退、format 作為副檔名。",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Twitter Image Saver"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "downloads",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "*://x.com/*",
    "*://twitter.com/*",
    "*://pbs.twimg.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://x.com/*", "*://twitter.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
